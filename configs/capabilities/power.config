# configs/capabilities/power.config
#
# Power Management features for Aurora-Kernel (Linux 6.18 LTS)

# --- Runtime PM (Power Management) ---
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_PM_SLEEP_SMP=y
CONFIG_PM_RUNTIME=y
CONFIG_PM_ADVANCED_DEBUG=y
CONFIG_PM_CLK=y
CONFIG_PM_DEBUG=n

# --- Generic Power Domains (GenPD) ---
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_PM_GENERIC_DOMAINS_OF=y
CONFIG_PM_GENERIC_DOMAINS_SLEEP=y

# --- PM QoS (Quality of Service) ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_TIMES=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# --- Devfreq ---
CONFIG_PM_DEVFREQ=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_GOV_PERFORMANCE=y
CONFIG_DEVFREQ_GOV_POWERSAVE=y
CONFIG_DEVFREQ_GOV_USERSPACE=y
CONFIG_DEVFREQ_GOV_PASSIVE=y

# --- OPP (Operating Performance Points) ---
CONFIG_OPP=y
CONFIG_PM_OPP=y

# --- ICC (Interconnect) ---
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_WAIPIO=y
CONFIG_INTERCONNECT_QCOM_SM8450=y

# --- IPA (Intelligent Power Allocator thermal governor) ---
CONFIG_THERMAL=y
CONFIG_THERMAL_HWMON=y
CONFIG_THERMAL_OF=y
CONFIG_THERMAL_WRITABLE_TRIPS=y
CONFIG_THERMAL_DEFAULT_GOV_POWER_ALLOCATOR=y
CONFIG_THERMAL_GOV_FAIR_SHARE=y
CONFIG_THERMAL_GOV_STEP_WISE=y
CONFIG_THERMAL_GOV_USER_SPACE=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y
CONFIG_QCOM_TSENS=y

# --- Thermal pressure (feed into scheduler) ---
CONFIG_SCHED_THERMAL_PRESSURE=y

# --- Suspend-to-idle ---
CONFIG_SUSPEND=y
CONFIG_SUSPEND_FREEZER=y
CONFIG_PM_SLEEP=y

# --- Clock framework ---
CONFIG_COMMON_CLK=y
CONFIG_COMMON_CLK_QCOM=y
CONFIG_QCOM_GDSC=y
CONFIG_CLKDEV_LOOKUP=y

# --- Regulator framework ---
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_REGULATOR_QCOM_SPMI=y

# --- Deep sleep optimization ---
CONFIG_HIBERNATION=n
CONFIG_PM_AUTOSLEEP=n
CONFIG_PM_WAKELOCKS=y
CONFIG_PM_WAKELOCKS_LIMIT=0

# --- Idle residency optimization ---
CONFIG_CPU_IDLE_MULTIPLE_DRIVERS=y
CONFIG_CPU_IDLE_GOV_TEO=y

# --- Watchdog (keep but allow runtime disable) ---
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_NOWAYOUT=n
CONFIG_QCOM_WDT=y

# --- Powercap ---
CONFIG_POWERCAP=y
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_QCOM=y
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY=y
CONFIG_CHARGER=y
