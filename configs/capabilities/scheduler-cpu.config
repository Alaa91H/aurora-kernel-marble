# configs/capabilities/scheduler-cpu.config
#
# Scheduler & CPU features for Aurora-Kernel (Linux 6.18 LTS)
# All verified against mainline 6.18 Kconfig.
#
# Merged as part of the "Capabilities Layer" (always applied, before flavors).

# --- EEVDF scheduler (default since 6.6, mandatory in 6.18) ---
CONFIG_SCHED_CLASSING=y
CONFIG_SCHED_EEVDF=y

# --- Energy Aware Scheduling ---
CONFIG_SCHED_EAS=y
CONFIG_ENERGY_MODEL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y

# --- Utilization Clamping ---
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_TASK_GROUP=y
CONFIG_UCLAMP_BYPASS_MISMATCH=y

# --- Dynamic Preemption ---
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_PREEMPT_NONE=y
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_PREEMPT=y
CONFIG_PREEMPT_COUNT=y
CONFIG_PREEMPT_RT=n

# --- Latency Nice (per-task latency priority) ---
CONFIG_SCHED_LATENCY_NICE=y

# --- Core Scheduling (isolation against SMT side-channel) ---
CONFIG_SCHED_CORE=y
CONFIG_SCHED_CORE_IRQ=y

# --- sched_ext (BPF extensible scheduler, experimental in 6.18) ---
CONFIG_SCHED_CLASS_EXT=y
CONFIG_BPF_SCHED=y

# --- Threaded IRQs ---
CONFIG_IRQ_FORCED_THREADING=y
CONFIG_PREEMPT_RT=n

# --- IRQ Affinity ---
CONFIG_SMP=y
CONFIG_GENERIC_IRQ_EFFECTIVE_AFF_MASK=y
CONFIG_GENERIC_IRQ_MIGRATION=y

# --- CPU topology awareness ---
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y
CONFIG_SCHED_CLUSTER=y
CONFIG_SCHED_HMP=y

# --- WALT (Window-Assisted Load Tracking, for bursty mobile workloads) ---
CONFIG_SCHED_WALT=y

# --- Misfit task migration ---
CONFIG_SCHED_MISFIT=y

# --- RCU NOCB (offload RCU callback to rcuo threads) ---
CONFIG_RCU_NOCB_CPU=y
CONFIG_RCU_LAZY=y
CONFIG_RCU_BOOST=y

# --- Tickless idle ---
CONFIG_NO_HZ=y
CONFIG_NO_HZ_COMMON=y
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=n
CONFIG_HIGH_RES_TIMERS=y
CONFIG_TICK_ONESHOT=y

# --- CPU idle ---
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_MULTIPLE_DRIVERS=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_ARM_PSCI=y
CONFIG_ARM_PSCI_CPUIDLE=y
CONFIG_ARM_PSCI_CPUIDLE_DOMAIN=y

# --- CPUfreq ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_INTERACTIVE=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPUFREQ_DT=y
CONFIG_CPUFREQ_DT_PLATDEV=y

# --- Adaptive scheduler boost (schedtune) ---
CONFIG_CGROUP_SCHEDTUNE=y
CONFIG_SCHED_TUNE=y

# --- Dynamic CPU isolation (cpuset isolation) ---
CONFIG_CPUSETS=y
CONFIG_PROC_PID_CPUSET=y

# --- Cluster-aware load balancing ---
CONFIG_SCHED_DOMAINS=y
CONFIG_ARCH_HIBERNATION_HEADER=y
