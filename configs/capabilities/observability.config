# configs/capabilities/observability.config
#
# Observability & Tracing features for Aurora-Kernel (Linux 6.18 LTS)
# Mandated by spec: "Observable Behavior Through Tracing"

# --- eBPF ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_BPF_EVENTS=y
CONFIG_BPF_KPROBE_OVERRIDE=y
CONFIG_BPF_TRAMPOLINE=y
CONFIG_HAVE_EBPF_JIT=y

# --- BTF (BPF Type Format) ---
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y
CONFIG_PAHOLE_HAS_SPLIT_BTF=y
CONFIG_PAHOLE_HAS_BTF_TAG=y

# --- CO-RE (Compile Once - Run Everywhere) ---
# Enabled via BTF; no separate Kconfig — BTF presence = CO-RE ready

# --- perf events ---
CONFIG_PERF_EVENTS=y
CONFIG_HW_PERF_EVENTS=y
CONFIG_ARM_PMU=y
CONFIG_ARM_PMUV3=y
CONFIG_ARM_DSU_PMU=y
CONFIG_QCOM_L3_PMU=y

# --- ftrace ---
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_TRACEPOINTS=y
CONFIG_TRACING=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_HIST_TRIGGERS=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_DYNAMIC_FTRACE_WITH_REGS=y
CONFIG_DYNAMIC_FTRACE_WITH_DIRECT_CALLS=y

# --- tracefs ---
CONFIG_TRACING_SUPPORT=y
CONFIG_TRACEFS=y

# --- hwlatdetect (hardware latency detector) ---
CONFIG_HWLAT_TRACER=y

# --- osnoise (OS noise tracer) ---
CONFIG_OSNOISE_TRACER=y

# --- timerlat (timer latency tracer) ---
CONFIG_TIMERLAT_TRACER=y

# --- trace-cmd support (trace_marker) ---
CONFIG_TRACE_MARKER=y

# --- kprobes / uprobe tracing ---
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y
CONFIG_KPROBES_ON_FTRACE=y
CONFIG_UPROBES=y
CONFIG_UPROBE_EVENTS=y

# --- Debugfs (needed for tracing) ---
CONFIG_DEBUG_FS=y

# --- printk ---
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DEBUG_INFO_BTF=y

# --- kallsyms (for tracing symbol resolution) ---
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_KALLSYMS_BASE_RELATIVE=y
