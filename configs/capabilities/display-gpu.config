# configs/capabilities/display-gpu.config
#
# Display & GPU control features for Aurora-Kernel (Linux 6.18 LTS)
# Marble: 120Hz AMOLED (Tianma/CSOT) + Adreno 725 GPU.

# --- DRM (Direct Rendering Manager) ---
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_DSI=y
CONFIG_DRM_MSM_DPU=y

# --- DSI (Display Serial Interface) ---
CONFIG_DRM_MSM_DSI_7NM_PHY=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_BRIDGE=y
CONFIG_DRM_PANEL_MIPI_DSI=y
CONFIG_DRM_PANEL_SIMPLE=y

# --- Panel drivers (marble uses Tianma + CSOT AMOLED) ---
CONFIG_DRM_PANEL_TIANMA=y
CONFIG_DRM_PANEL_CSOT=y

# --- Framebuffer / fbdev emulation ---
CONFIG_FB=y
CONFIG_FB_ARMCLCD=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_FBDEV_OVERALLOC=100

# --- Vblank / TE (Tearing Effect) ---
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_VBLANK=y

# --- Backlight (PWM for DC dimming / AOD) ---
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_LCD_SUPPORT=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_BACKLIGHT_LP855X=y
CONFIG_BACKLIGHT_QCOM_WLED=y
CONFIG_PWM=y
CONFIG_PWM_QCOM=y

# --- GPU (Adreno 725) ---
CONFIG_QCOM_KGSL=y
CONFIG_QCOM_KGSL_HWMON=y
CONFIG_QCOM_ADRENO_GPU=y
CONFIG_QCOM_ADRENO_SMMU=y
CONFIG_GPU_PWRDCOLLECTOR=y

# --- GPU devfreq (frequency scaling) ---
CONFIG_PM_DEVFREQ=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_GOV_PERFORMANCE=y
CONFIG_DEVFREQ_GOV_POWERSAVE=y
CONFIG_DEVFREQ_GOV_USERSPACE=y
CONFIG_DEVFREQ_GOV_PASSIVE=y

# --- Display power domains ---
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_RPMPD=y
CONFIG_POWER_DOMAIN=y

# --- Refresh rate hints (runtime via DSI command queue) ---
# The kernel provides the DSI command queue + TE interrupt;
# SurfaceFlinger/HWC uses it to switch refresh rates.
# No separate Kconfig — part of DRM_MSM_DSI.

# --- Touch boost hint ---
# Touchscreen driver (Focaltech FT8006) reports touch events;
# the Aurora runtime daemon boosts CPU on touch.
# No separate Kconfig — relies on INPUT_EVDEV + cpufreq.
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_TOUCHSCREEN_FTS=y
