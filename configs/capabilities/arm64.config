# configs/capabilities/arm64.config
#
# ARM64 architecture features for Aurora-Kernel (Linux 6.18 LTS)
# SM7475 = Cortex-A715 + Cortex-A510 (ARMv9.0-A)

# --- SVE2 (Scalable Vector Extension v2) ---
CONFIG_ARM64_SVE=y
CONFIG_ARM64_SME=y

# --- BTI (Branch Target Identification) ---
CONFIG_ARM64_BTI=y
CONFIG_ARM64_BTI_KERNEL=y

# --- PAC (Pointer Authentication Codes) ---
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_PTR_AUTH_KERNEL=y

# --- MTE (Memory Tagging Extension) ---
CONFIG_ARM64_MTE=y

# --- GICv3 (Generic Interrupt Controller v3) ---
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_GIC_V3_ITS=y
CONFIG_ARM_GIC_V3_ITS_PCI=y
CONFIG_ARM_GIC_V3_ITS_FSL_MC=y

# --- PSCI (Power State Coordination Interface) ---
CONFIG_ARM_PSCI=y
CONFIG_ARM_PSCI_FW=y
CONFIG_ARM_PSCI_CHECKER=n

# --- cpuidle ---
CONFIG_ARM_CPUIDLE=y
CONFIG_ARM_PSCI_CPUIDLE=y
CONFIG_ARM_PSCI_CPUIDLE_DOMAIN=y

# --- cpufreq ---
CONFIG_ARM_SCPI_CPUFREQ=n
CONFIG_ARM_SCMI_CPUFREQ=n
CONFIG_ARM_QCOM_CPUFREQ_NVMEM=y

# --- Topology awareness ---
CONFIG_ACPI_PPTT=y
CONFIG_ARM64_AMU_EXTN=y
CONFIG_ARM64_CPUID=y
CONFIG_ARM64_HW_AFDBM=y

# --- ARM64 capabilities ---
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_CONTPTE=y
CONFIG_ARM64_EPAN=y
CONFIG_ARM64_E0PD=y
CONFIG_ARM64_PAN=y
CONFIG_ARM64_UAO=y
CONFIG_ARM64_VA_BITS_39=y
CONFIG_ARM64_PA_BITS_48=y
CONFIG_ARM64_TAGGED_ADDR=y
CONFIG_ARM64_SW_TTBR0_PAN=y
CONFIG_ARM64_WORKAROUND_CLEAN_CACHE=y

# --- Cache ---
CONFIG_ARCH_HAS_CACHE_LINE_SIZE=y
CONFIG_CACHE_L2X0=y
CONFIG_QCOM_LLCC=y

# --- ARM SMMU (System MMU) ---
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y
CONFIG_ARM_SMMU_V3_SVA=y

# --- Qualcomm IOMMU ---
CONFIG_QCOM_IOMMU=y

# --- NVMEM ---
CONFIG_NVMEM=y
CONFIG_QCOM_QFPROM=y

# --- DMA ---
CONFIG_DMADEVICES=y
CONFIG_QCOM_BAM_DMA=y
CONFIG_QCOM_HIDMA=y
CONFIG_QCOM_HIDMA_MGMT=y
