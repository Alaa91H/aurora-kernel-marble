# configs/capabilities/aurora-exclusive.config
#
# Aurora-Kernel exclusive features (the project's distinguishing layer)
#
# These CONFIG options enable the kernel infrastructure that the Aurora
# runtime engine (aurora-tune.sh + init.aurora.rc) uses to provide
# advanced power/thermal/scheduler management.
#
# The "Aurora Dynamic Power Engine", "Intelligent Thermal Engine", etc.
# are runtime services (userspace daemons + sysfs), not kernel modules.
# This config enables the kernel-side hooks they depend on.

# --- Aurora Telemetry Engine ---
# Relies on: eBPF, BTF, perf, ftrace, PSI (all in observability.config)
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_BPF_LSM=y
CONFIG_PERF_EVENTS=y
CONFIG_PSI=y

# --- Aurora Dynamic Power Engine ---
# Relies on: CPUFreq, Devfreq, OPP, ICC, Runtime PM, thermal
CONFIG_CPU_FREQ=y
CONFIG_PM_DEVFREQ=y
CONFIG_OPP=y
CONFIG_INTERCONNECT=y
CONFIG_PM=y
CONFIG_PM_RUNTIME=y
CONFIG_THERMAL=y
CONFIG_SCHED_THERMAL_PRESSURE=y

# --- Aurora Intelligent Thermal Engine ---
# Relies on: IPA thermal governor, thermal zones, thermal pressure
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y
CONFIG_QCOM_TSENS=y
CONFIG_QCOM_BCL=y

# --- Aurora Memory Optimizer ---
# Relies on: MGLRU, DAMON/DAMOS, zRAM, KSM, compaction
CONFIG_LRU_GEN=y
CONFIG_DAMON=y
CONFIG_DAMON_RECLAIM=y
CONFIG_ZRAM=y
CONFIG_KSM=y
CONFIG_COMPACTION=y

# --- Aurora IO Optimizer ---
# Relies on: blk-mq, io_uring, BFQ, writeback throttling, read-ahead
CONFIG_BLK_DEV=y
CONFIG_BLK_WBT=y
CONFIG_IO_URING=y
CONFIG_IOSCHED_BFQ=y
CONFIG_MQ_IOSCHED_DEADLINE=y

# --- Aurora Scheduler Policy Manager ---
# Relies on: PREEMPT_DYNAMIC, EAS, UCLAMP, schedtune, Core Scheduling
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_SCHED_EAS=y
CONFIG_UCLAMP_TASK=y
CONFIG_CGROUP_SCHEDTUNE=y
CONFIG_SCHED_CORE=y

# --- Aurora Battery Guardian ---
# Relies on: power supply, charger sysfs, BCL (battery current limiter)
CONFIG_POWER_SUPPLY=y
CONFIG_CHARGER=y
CONFIG_QCOM_BCL=y

# --- Aurora Live Profile Switching ---
# Relies on: sysfs cpufreq/devfreq/thermal + init property triggers
# (handled by init.aurora.rc + aurora-tune.sh)
CONFIG_CPU_FREQ=y
CONFIG_PM_DEVFREQ=y
CONFIG_THERMAL_WRITABLE_TRIPS=y

# --- Aurora OTA Compatibility Layer ---
# GKI compliance ensures OTA kernel updates don't break
CONFIG_GKI_HACKS_TO_FIX=y
CONFIG_KMI_SYMBOL_LIST=y
CONFIG_MODVERSIONS=y

# --- Aurora Vendor Compatibility Layer ---
# Vendor hooks allow vendor modules to extend core without patching
CONFIG_ANDROID_VENDOR_HOOKS=y

# --- Aurora Safe Mode Boot ---
# Relies on: pstore, ramoops, panic_on_oops
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=5
CONFIG_MAGIC_SYSRQ=y

# --- Aurora Diagnostics Suite ---
# Relies on: debugfs, ftrace, kprobes, dynamic debug
CONFIG_DEBUG_FS=y
CONFIG_FTRACE=y
CONFIG_KPROBES=y
CONFIG_DYNAMIC_DEBUG=y
CONFIG_PROC_SYSCTL=y

# --- Aurora Build Manifest System ---
# The manifest is generated by CI; this ensures the kernel reports
# its version + build info correctly.
CONFIG_LOCALVERSION_AUTO=y
CONFIG_LOCALVERSION="-aurora"
CONFIG_BUILD_SALT=""
