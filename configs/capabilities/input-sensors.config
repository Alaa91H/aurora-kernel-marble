# configs/capabilities/input-sensors.config
#
# Input, sensors, haptics, and peripherals for Aurora-Kernel (SM7475)

# --- Input core ---
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_UINPUT=y
CONFIG_INPUT_GPIO=y

# --- Touchscreen (Focaltech FT8006) ---
CONFIG_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_FTS=y
CONFIG_TOUCHSCREEN_FT5x06=y

# --- Sensors (IIO — Industrial I/O) ---
CONFIG_IIO=y
CONFIG_IIO_BUFFER=y
CONFIG_IIO_BUFFER_CB=y
CONFIG_IIO_KFIFO_BUF=y
CONFIG_IIO_TRIGGERED_BUFFER=y
CONFIG_IIO_TRIGGER=y
CONFIG_IIO_CONSUMERS=y

# --- Qualcomm ADC (analog sensors) ---
CONFIG_QCOM_SPMI_VADC=y
CONFIG_QCOM_SPMI_ADC5=y
CONFIG_QCOM_VADC_COMMON=y

# --- Accelerometer / Gyroscope (BMI260 / LSM6DSO) ---
CONFIG_IIO_ST_ACCEL_3AXIS=y
CONFIG_IIO_ST_GYRO_3AXIS=y
CONFIG_IIO_ST_LSM6DSX=y

# --- Magnetometer ---
CONFIG_IIO_ST_MAGN_3AXIS=y

# --- Proximity / Ambient light (TCS3701) ---
CONFIG_IIO_ST_LIGHT=y
CONFIG_TCS3701=y

# --- Haptics (PMI632 LRA linear resonant actuator) ---
CONFIG_QCOM_SPMI_HAPTICS=y
CONFIG_INPUT_QCOM_HAPTICS=y
CONFIG_QPNP_HAPTICS=y

# --- LEDs ---
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_CLASS_FLASH=y
CONFIG_LEDS_CLASS_MULTICOLOR=y
CONFIG_LEDS_TRIGGER_TIMER=y
CONFIG_LEDS_TRIGGER_PATTERN=y
CONFIG_QPNP_LED=y
CONFIG_QPNP_PWM=y

# --- RTC (real-time clock) ---
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_PM8XXX=y
CONFIG_RTC_DRV_QPNP=y

# --- Fingerprint (Goodix / FPC) ---
CONFIG_INPUT_FINGERPRINT=y
CONFIG_FINGERPRINT_GOODIX=y

# --- Vibrator ---
CONFIG_INPUT_MISC=y
CONFIG_QCOM_PMIC_VIBRATOR=y

# --- Keys / buttons ---
CONFIG_KEYBOARD_GPIO=y
CONFIG_KEYBOARD_PMIC8XXX=y
CONFIG_GPIO_KEYS=y
