# configs/capabilities/networking.config
#
# Networking features for Aurora-Kernel (Linux 6.18 LTS)

# --- Core ---
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_PACKET_DIAG=y
CONFIG_UNIX=y
CONFIG_UNIX_DIAG=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_SYN_COOKIES=y

# --- BIG TCP (larger GSO/TSO sizes for high throughput) ---
CONFIG_NET_BIG_TCP=y

# --- TCP AO (Authentication Option, replaces TCP MD5) ---
CONFIG_TCP_AO=y

# --- TCP Fast Open ---
CONFIG_TCP_FASTOPEN=y

# --- MPTCP (Multipath TCP) ---
CONFIG_MPTCP=y
CONFIG_MPTCP_IPV6=y

# --- Congestion control ---
CONFIG_TCP_CONG_CUBIC=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_DEFAULT_BBR_QDISC=y

# --- Queue disciplines ---
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_CAKE=y
CONFIG_NET_SCH_TBF=y
CONFIG_NET_SCH_PRIO=y
CONFIG_NET_SCH_INGRESS=y
CONFIG_NET_SCH_MULTIQ=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_NET_EMATCH=y

# --- WireGuard (in-kernel) ---
CONFIG_WIREGUARD=y

# --- XDP / AF_XDP (eXpress Data Path) ---
CONFIG_XDP_SOCKETS=y
CONFIG_XDP_SOCKETS_DIAG=y
CONFIG_BPF_SYSCALL=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_NET_XGENE=y

# --- Page Pool API ---
# Always enabled in 6.18 for network drivers — no separate Kconfig

# --- MSG_ZEROCOPY (zero-copy send) ---
# Enabled via CONFIG_BPF_SYSCALL + io_uring; no separate Kconfig

# --- MSG_SPLICE_PAGES (splice-based zero-copy) ---
# Part of core socket layer in 6.18 — no separate Kconfig

# --- io_uring networking ---
CONFIG_IO_URING=y
CONFIG_NET_RX_BUSY_POLL=y

# --- TLS offload (kernel TLS for HTTPS) ---
CONFIG_TLS=y
CONFIG_TLS_DEVICE=y

# --- NetDIM (Dynamic Interrupt Moderation) ---
# Driver-level feature; CONFIG enabled via the ethernet driver itself

# --- NAPI optimization ---
CONFIG_NET_POLL_CONTROLLER=y
CONFIG_NAPI=y

# --- IPv6 ---
CONFIG_IPV6=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_MROUTE=y
CONFIG_IPV6_PIMSM_V2=y
CONFIG_IPV6_SEG6_LWTUNNEL=y
CONFIG_IPV6_IOAM6_LWTUNNEL=y

# --- Netfilter / nftables ---
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_CONNMARK=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_MARK=y
CONFIG_NETFILTER_XT_MATCH_BPF=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_EVENTS=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NFT_CT=y
CONFIG_NFT_CHAIN_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_FIB=y
CONFIG_NFT_SOCKET=y
CONFIG_NFT_TUNNEL=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_MASQUERADE=y

# --- Bluetooth ---
CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_LE=y
CONFIG_BT_LEDS=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_QCA=y

# --- WiFi (QCA6490 WiFi 6E via PCIE, qcacld-3.0 vendor driver — NOT ath11k) ---
CONFIG_WLAN=y
CONFIG_CFG80211=y
CONFIG_CFG80211_WEXT=y
CONFIG_MAC80211=y
CONFIG_RFKILL=y
CONFIG_RFKILL_GPIO=y
# QCA6490 uses the qcacld-3.0 out-of-tree driver (built as vendor DLKM),
# NOT the mainline ath11k driver (that's for WCN7850, which marble does NOT use).

# --- USB networking ---
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y
CONFIG_USB_NET_CDCETHER=y
CONFIG_USB_NET_RNDIS_HOST=y
CONFIG_USB_NET_CDC_NCM=y
