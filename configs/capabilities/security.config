# configs/capabilities/security.config
#
# Security features for Aurora-Kernel (Linux 6.18 LTS)
# All verified against mainline 6.18 Kconfig.

# --- KCFI (Kernel Control Flow Integrity, Clang) ---
CONFIG_CFI_CLANG=y
CONFIG_CFI_PERMISSIVE=n

# --- MTE (Memory Tagging Extension, ARM64) ---
CONFIG_ARM64_MTE=y

# --- Shadow Call Stack (Clang) ---
CONFIG_SHADOW_CALL_STACK=y

# --- FORTIFY v2 (compile-time + runtime buffer overflow detection) ---
CONFIG_FORTIFY_SOURCE=y

# --- FGKASLR (Function Granular KASLR) ---
CONFIG_FG_KASLR=y

# --- Kernel Lockdown ---
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y

# --- SELinux ---
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_CHECKREQPROT_VALUE=0

# --- PAN (Privileged Access Never) ---
CONFIG_ARM64_PAN=y
CONFIG_ARM64_EPAN=y

# --- BTI (Branch Target Identification) ---
CONFIG_ARM64_BTI=y
CONFIG_ARM64_BTI_KERNEL=y

# --- PAC (Pointer Authentication) ---
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_PTR_AUTH_KERNEL=y

# --- KASLR (Kernel Address Space Layout Randomization) ---
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MODULE_REGION_FULL=y

# --- KFENCE (low-overhead memory error detector) ---
CONFIG_KFENCE=y
CONFIG_KFENCE_SAMPLE_INTERVAL=100

# --- LKDTM (Linux Kernel Dump Test Module, for security testing) ---
CONFIG_LKDTM=y

# --- BPF LSM (Linux Security Module via BPF) ---
CONFIG_BPF_LSM=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y

# --- IOMMUFD (new IOMMU subsystem, replaces /dev/iommu) ---
CONFIG_IOMMUFD=y
CONFIG_IOMMUFD_TEST=n

# --- Stack initialization (zero stack on alloc) ---
CONFIG_INIT_STACK_ALL_ZERO=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y

# --- Hardened usercopy ---
CONFIG_HARDENED_USERCOPY=y
CONFIG_HARDENED_USERCOPY_PAGESPAN=y

# --- Refcount hardening ---
CONFIG_REFCOUNT_FULL=y

# --- Speculative execution mitigations ---
CONFIG_SPECULATION_MITIGATIONS=y

# --- Stack protector ---
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# --- E0PD (arm64 equivalent of KPTI for Meltdown) ---
CONFIG_ARM64_E0PD=y
CONFIG_ARM64_SW_TTBR0_PAN=y
CONFIG_UNMAP_KERNEL_AT_EL0=y

# --- YAMA (restrict ptrace) ---
CONFIG_SECURITY_YAMA=y

# --- Landlock ---
CONFIG_SECURITY_LANDLOCK=y

# --- LSM chain ---
CONFIG_LSM="lockdown,yama,loadpin,safesetid,integrity,selinux,bpf,landlock"

# --- SLS (Straight-Line Speculation) ---
CONFIG_HARDEN_BRANCH_PREDICTOR=y

# --- RODATA full ---
CONFIG_RODATA_FULL_DEFAULT_ENABLED=y
