# configs/capabilities/build-system.config
#
# Build system & toolchain features for Aurora-Kernel (Linux 6.18 LTS)
# Aligns with ADR-0001 (upstream-first) and spec §12 (reproducible builds).

# --- LLVM/Clang toolchain ---
CONFIG_CC_IS_CLANG=y
CONFIG_LD_IS_LLD=y
CONFIG_CC_VERSION_TEXT="Clang 17+"
CONFIG_LD_VERSION=170000

# --- ThinLTO (Link-Time Optimization) ---
CONFIG_LTO=y
CONFIG_LTO_CLANG=y
CONFIG_LTO_CLANG_THIN=y
CONFIG_LTO_NONE=n

# --- BTF (BPF Type Format, required for CO-RE + modern tooling) ---
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y
CONFIG_PAHOLE_HAS_SPLIT_BTF=y

# --- Reproducible builds ---
# SOURCE_DATE_EPOCH is set at build time; these Kconfig ensure determinism
CONFIG_REPRODUCIBLE_BUILD=y
CONFIG_DEBUG_INFO_NONE=n
CONFIG_DEBUG_INFO_DWARF5=n

# --- objtool (stack validation, ORC unwinder) ---
CONFIG_OBJTOOL=y
CONFIG_UNWINDER_ORC=y
CONFIG_UNWINDER_FRAME_POINTER=n
CONFIG_STACK_VALIDATION=y

# --- pahole (for BTF generation) ---
# No Kconfig — build-time tool dependency; CI installs pahole

# --- KUnit (in-kernel unit testing) ---
CONFIG_KUNIT=y
CONFIG_KUNIT_DEBUGFS=y
CONFIG_KUNIT_EXAMPLE_TEST=n

# --- kselftest (subsystem selftest framework) ---
CONFIG_KSELFTEST=y

# --- Static analysis hooks (runtime, not compile) ---
CONFIG_UBSAN=y
CONFIG_UBSAN_BOUNDS=y
CONFIG_SPARSE_RCU_POINTER=y

# --- Module signing ---
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA256=y
CONFIG_MODULE_SIG_HASH="sha256"
CONFIG_MODULE_SIG_KEY="certs/signing_key.pem"

# --- BOLT / PGO (future, when stable) ---
# CONFIG_LTO_POLINE is not set  (not yet stable in 6.18)
# CONFIG_PGO is not set          (not yet stable in 6.18)

# --- KASAN (dev only — controlled by profile layer) ---
# Left to profile/development.config to enable

# --- Compiler hardening ---
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_STACK_ALL_ZERO=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
