# configs/capabilities/filesystems.config
#
# Filesystem support for Aurora-Kernel (Linux 6.18 LTS)
# Comprehensive filesystem matrix per spec §11.

# --- EXT4 (primary for system/vendor) ---
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_EXT4_FS_ENCRYPTION=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_JBD2=y

# --- F2FS (primary for userdata) ---
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_XATTR=y
CONFIG_F2FS_FS_POSIX_ACL=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_F2FS_FS_ENCRYPTION=y
CONFIG_F2FS_FS_COMPRESSION=y
CONFIG_F2FS_STAT_FS=y

# --- EROFS (read-only compressed for system/vendor partitions) ---
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_XATTR=y
CONFIG_EROFS_FS_POSIX_ACL=y
CONFIG_EROFS_FS_SECURITY=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_LZ4=y
CONFIG_EROFS_FS_ZIP_DEFLATE=y

# --- OverlayFS (overlay mounts for Android) ---
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_METACOPY=y

# --- Incremental FS (Android AOT app installation) ---
CONFIG_INCREMENTAL_FS=y

# --- FAT/exFAT (external storage) ---
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="utf8"
CONFIG_EXFAT_FS=y

# --- NTFS3 (Paragon, for external NTFS drives) ---
CONFIG_NTFS3_FS=y
CONFIG_NTFS3_LZX_XPRESS=y
CONFIG_NTFS3_FS_POSIX_ACL=y

# --- ISO9660 (CD images) ---
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y
CONFIG_ZISOFS=y

# --- UDF (DVD/USB) ---
CONFIG_UDF_FS=y

# --- Proc / Sys / Tmpfs ---
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_PROC_PAGE_MONITOR=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_CONFIGFS_FS=y
CONFIG_SECURITYFS=y

# --- Quota ---
CONFIG_QUOTA=y
CONFIG_QUOTACTL=y
CONFIG_QUOTA_TREE=y

# --- Fscrypt (file-based encryption) ---
CONFIG_FS_ENCRYPTION=y
CONFIG_FS_ENCRYPTION_INLINE_CRYPT=y
CONFIG_FSCRYPT=y
CONFIG_FSCRYPT_ADVANCED_HMAC=y

# --- fs-verity ---
CONFIG_FS_VERITY=y
CONFIG_FS_VERITY_BUILTIN_SIGNATURES=y

# --- dm-verity ---
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_FEC=y

# --- NFS (optional, for network storage) ---
CONFIG_NFS_FS=n
CONFIG_NFSD=n

# --- CIFS/SMB (optional) ---
CONFIG_CIFS=n

# --- Pstore (persistent store for crash logs) ---
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y

# --- FUSE (userspace filesystems) ---
CONFIG_FUSE_FS=y

# --- Cache ---
CONFIG_FSCACHE=y
CONFIG_CACHEFILES=y
