# configs/capabilities/android.config
#
# Android compatibility features for Aurora-Kernel (Linux 6.18 LTS)
# Ensures full GKI / KMI / Android compliance.

# --- GKI (Generic Kernel Image) ---
CONFIG_GKI_HACKS_TO_FIX=y

# --- KMI (Kernel Module Interface) stability ---
CONFIG_KMI_SYMBOL_LIST=y
CONFIG_KMI_ENFORCED=y
CONFIG_MODVERSIONS=y
CONFIG_MODULE_FORCE_LOAD=n
CONFIG_MODULE_FORCE_UNLOAD=n

# --- Binder (IPC) ---
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"

# --- Ashmem (shared memory, legacy) ---
CONFIG_ASHMEM=y

# --- Incremental FS (AOT app installation) ---
CONFIG_INCREMENTAL_FS=y

# --- Vendor DLKM support ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_COMPRESS_XZ=y
CONFIG_MODULE_DECOMPRESS=y

# --- init_boot support (Android 13+ ramdisk split) ---
# No kernel Kconfig — handled by mkbootimg/AnyKernel3 at packaging time

# --- vendor_boot support ---
# No kernel Kconfig — handled by mkbootimg/AnyKernel3 at packaging time

# --- DTBO (Device Tree Blob Overlay) ---
CONFIG_OF=y
CONFIG_OF_FLATTREE=y
CONFIG_OF_EARLY_FLATTREE=y
CONFIG_OF_DYNAMIC=y
CONFIG_OF_ADDRESS=y
CONFIG_OF_IRQ=y
CONFIG_OF_RESERVED_MEM=y

# --- dm-verity (verified boot for system/vendor) ---
CONFIG_MD=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_FEC=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=y

# --- fs-verity (file-based verified boot) ---
CONFIG_FS_VERITY=y
CONFIG_FS_VERITY_BUILTIN_SIGNATURES=y

# --- Inline encryption (for FBE file-based encryption) ---
CONFIG_FS_ENCRYPTION=y
CONFIG_FS_ENCRYPTION_INLINE_CRYPT=y
CONFIG_FSCRYPT=y
CONFIG_FSCRYPT_ADVANCED_HMAC=y

# --- Android tracepoints ---
CONFIG_TRACEPOINTS=y
CONFIG_FTRACE=y
CONFIG_ANDROID_TRACE=y

# --- Android memory hooks (low memory killer, etc.) ---
CONFIG_MEMCG=y
CONFIG_PSI=y
CONFIG_LMKD=y

# --- Android boot requirements ---
CONFIG_BLK_DEV_INITRD=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_CONFIGFS_FS=y

# --- Vendor module interface ---
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA256=y
CONFIG_MODULE_SIG_HASH="sha256"

# --- DMA-BUF (graphics buffer sharing) ---
CONFIG_DMA_SHARED_BUFFER=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_DMABUF_SYSFS_STATS=y
