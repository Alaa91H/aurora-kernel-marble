# configs/capabilities/battery-charging.config
#
# Battery & charging control features for Aurora-Kernel (Linux 6.18 LTS)
# Some features depend on PMIC driver support (marble uses Qualcomm PMIC).

# --- Battery fuel gauge ---
CONFIG_BATTERY=y
CONFIG_BATTERY_BQ27XXX=y
CONFIG_BATTERY_BQ27XXX_I2C=y
CONFIG_BATTERY_BQ27XXX_DT_UPDATES_NVM=y

# --- Charger control ---
CONFIG_CHARGER=y
CONFIG_CHARGER_QCOM_SMBB=y
CONFIG_CHARGER_QCOM_SMB1390=y
CONFIG_CHARGER_QCOM_SMB2=y
CONFIG_QPNP_CHARGER=y
CONFIG_QPNP_SMB2=y
CONFIG_QPNP_TYPEC=y
CONFIG_QPNP_USB_PDPHY=y

# --- USB current limiting ---
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_MSM=y
CONFIG_USB_DWC3_DUAL_ROLE=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_TCPCI=y
CONFIG_TYPEC_UCSI=y
CONFIG_TYPEC_QCOM_PMIC=y

# --- Power supply (sysfs interface for userspace control) ---
CONFIG_POWER_SUPPLY=y
CONFIG_POWER_SUPPLY_HWMON=y
CONFIG_CHARGER_SYSFS=y

# --- Battery health protection ---
# Runtime-controlled via /sys/class/power_supply/battery/
# - charge_control_limit_max
# - charge_control_limit_target
# - constant_charge_current_max
# - input_current_limit
CONFIG_POWER_SUPPLY_EXT=y

# --- Adaptive charging framework ---
# The kernel exposes charging knobs via sysfs; the Aurora runtime
# daemon (aurora-tune.sh) sets them based on the active profile.
# No separate Kconfig — relies on POWER_SUPPLY + CHARGER above.

# --- Thermal charging control ---
CONFIG_THERMAL=y
CONFIG_QCOM_BCL=y
CONFIG_QCOM_BCL_PERIPHERAL=y

# --- Battery statistics ---
CONFIG_BATTERY_CAPACITY_DIRTY=y
CONFIG_BATTERY_BATTERY_INFO=y

# --- USB role switch (for USB-C power roles) ---
CONFIG_USB_ROLE_SWITCH=y
CONFIG_USB_ROLES_INTEL_XHCI=y

# --- Power accounting ---
CONFIG_POWERCAP=y
CONFIG_ARM_SCMI_PROTOCOL=y
