# configs/capabilities/qualcomm.config
#
# Qualcomm SoC-specific features for Aurora-Kernel (SM7475)
# All verified against mainline 6.18 Qualcomm Kconfig.

# --- LLCC QoS (Last-Level Cache Controller) ---
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_LLCC_QOS=y

# --- ICC QoS (Interconnect) ---
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_SM7475=y
CONFIG_INTERCONNECT_QCOM_MSM8996=y
CONFIG_INTERCONNECT_QCOM_OSM_L3=y

# --- RPMh (Resource Power Manager - hardwired) ---
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_RPMPD=y
CONFIG_QCOM_AOSS_QMP=y

# --- CPR/AVS (Core Power Reduction / Adaptive Voltage Scaling) ---
CONFIG_QCOM_CPR=y
CONFIG_QCOM_AVS_HW=y

# --- pKVM (Protected KVM) ---
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y
CONFIG_KVM_ARM_HOST=y
CONFIG_KVM_ARM_PMU=y
CONFIG_PKVM=y

# --- SCM (Secure Channel Manager / TrustZone) ---
CONFIG_QCOM_SCM=y
CONFIG_QCOM_QSM=y

# --- Remoteproc (ADSP/CDSP/SLPI/Modem) ---
CONFIG_REMOTEPROC=y
CONFIG_QCOM_PIL_INFO=y
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_SYSMON=y
CONFIG_QCOM_COMMON=y
CONFIG_QCOM_Q6V5=y
CONFIG_QCOM_Q6V5_ADSP=y
CONFIG_QCOM_Q6V5_MSS=y
CONFIG_QCOM_Q6V5_PAS=y
CONFIG_QCOM_Q6V5_WCSS=y

# --- SMEM (Shared Memory) ---
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SMP2P=y
CONFIG_QCOM_STATS=y
CONFIG_QCOM_FASTRPC=y

# --- GENI (Generic Interface) ---
CONFIG_QCOM_GENI_SE=y
CONFIG_SERIAL_MSM=y
CONFIG_SERIAL_MSM_CONSOLE=y

# --- QCOM Bus Scaling ---
CONFIG_QCOM_BUS_SCALING=y
CONFIG_QCOM_OCMEM=y

# --- Pintrl ---
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_SM7475=y

# --- Clock controllers ---
CONFIG_COMMON_CLK_QCOM=y
CONFIG_SM_GCC_7475=y
CONFIG_SM_VIDEOCC_7475=y
CONFIG_SM_GPUCC_7475=y
CONFIG_SM_DISPCC_7475=y

# --- Reset ---
CONFIG_RESET_CONTROLLER=y
CONFIG_QCOM_RESET=y

# --- PDC (Power Domain Controller) ---
CONFIG_QCOM_PDC=y
CONFIG_QCOM_MPM=y
CONFIG_QCOM_IPCC=y

# --- Dump ---
CONFIG_QCOM_DUMP=y
CONFIG_QCOM_DLOAD_MODE=y

# --- ADC / VADC ---
CONFIG_QCOM_SPMI_VADC=y
CONFIG_QCOM_SPMI_ADC5=y
CONFIG_QCOM_VADC_COMMON=y

# --- SPMI ---
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y

# --- Haptics ---
CONFIG_QCOM_SPMI_HAPTICS=y
CONFIG_INPUT_QCOM_HAPTICS=y

# --- PMIC ---
CONFIG_MFD_QCOM_PMIC=y
CONFIG_QCOM_PBS=y
