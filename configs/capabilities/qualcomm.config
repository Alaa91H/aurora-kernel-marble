# configs/capabilities/qualcomm.config
#
# Qualcomm SoC-specific features for Aurora-Kernel
# Platform: SM8450 (waipio/taro) base, SM7475 (diwali) die
# VERIFIED from marble_GKI.config (Xiaomi marble-s-oss)

# --- 3 platform arches (marble spans waipio + diwali + cape) ---
CONFIG_ARCH_WAIPIO=y
CONFIG_ARCH_DIWALI=y
CONFIG_ARCH_CAPE=y

# --- LLCC QoS (Last-Level Cache Controller) ---
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_LLCC_PERFMON=y
CONFIG_QCOM_LLCC_PMU=y

# --- ICC QoS (Interconnect — 3 platforms) ---
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_WAIPIO=y
CONFIG_INTERCONNECT_QCOM_DIWALI=y
CONFIG_INTERCONNECT_QCOM_PARROT=y
CONFIG_INTERCONNECT_QCOM_DEBUG=y

# --- RPMh (Resource Power Manager) ---
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_RPMPD=y
CONFIG_QCOM_AOSS_QMP=y
CONFIG_QCOM_CLK_RPMH=y

# --- CPR/AVS (Core Power Reduction / Adaptive Voltage Scaling) ---
CONFIG_QCOM_CPR=y
CONFIG_QCOM_AVS_HW=y

# --- pKVM (Protected KVM) ---
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y
CONFIG_KVM_ARM_HOST=y
CONFIG_KVM_ARM_PMU=y
CONFIG_PKVM=y

# --- Gunyah hypervisor (Qualcomm native hypervisor) ---
CONFIG_GUNYAH_DRIVERS=y
CONFIG_GH_ARM64_DRV=y
CONFIG_GH_CTRL=y
CONFIG_GH_IRQ_LEND=y
CONFIG_GH_MEM_NOTIFIER=y
CONFIG_GH_MSGQ=y
CONFIG_GH_RM_DRV=y
CONFIG_GH_VIRTIO_BACKEND=y
CONFIG_HVC_GUNYAH=y
CONFIG_QCOM_GUESTVM=y

# --- SCM (Secure Channel Manager / TrustZone) ---
CONFIG_QCOM_SCM=y
CONFIG_QCOM_SMCINVOKE=y
CONFIG_QCOM_SECURE_BUFFER=y
CONFIG_QTI_TZ_LOG=y

# --- Remoteproc (ADSP/CDSP/SLPI/Modem via PAS) ---
CONFIG_REMOTEPROC=y
CONFIG_QCOM_PIL_INFO=y
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_SYSMON=y
CONFIG_QCOM_COMMON=y
CONFIG_QCOM_Q6V5=y
CONFIG_QCOM_Q6V5_PAS=y
# CONFIG_QCOM_Q6V5_ADSP is not set
# CONFIG_QCOM_Q6V5_MSS is not set
# CONFIG_QCOM_Q6V5_WCSS is not set
CONFIG_MSM_ADSPRPC=y
CONFIG_MSM_CDSP_LOADER=y

# --- SMEM (Shared Memory) ---
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SMP2P=y
CONFIG_QCOM_SMP2P_SLEEPSTATE=y
CONFIG_QCOM_SOCINFO=y
CONFIG_QCOM_STATS=y
CONFIG_QCOM_FASTRPC=y

# --- GENI (Generic Interface) ---
CONFIG_QCOM_GENI_SE=y
CONFIG_MSM_GENI_SE=y
CONFIG_SERIAL_MSM_GENI=y
CONFIG_SERIAL_MSM_GENI_CONSOLE=y
CONFIG_SPI_MSM_GENI=y
CONFIG_I2C_MSM_GENI=y
CONFIG_I3C_MASTER_MSM_GENI=y

# --- QCOM Bus Scaling ---
CONFIG_QCOM_BUS_SCALING=y
CONFIG_QCOM_OCMEM=y

# --- Pintrl (3 platforms) ---
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_WAIPIO=y
CONFIG_PINCTRL_DIWALI=y
CONFIG_PINCTRL_CAPE=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y

# --- Clock controllers ---
# MSM_*CC_WAIPIO (GCC/GPUCC/CAMCC/DEBUGCC/DISPCC/VIDEOCC)
CONFIG_COMMON_CLK_QCOM=y
CONFIG_MSM_GCC_WAIPIO=y
CONFIG_MSM_CAMCC_WAIPIO=y
CONFIG_MSM_DEBUGCC_WAIPIO=y
CONFIG_MSM_DISPCC_WAIPIO=y
CONFIG_MSM_GPUCC_WAIPIO=y
CONFIG_MSM_VIDEOCC_WAIPIO=y
# SM_*CC_DIWALI (CAMCC/DEBUGCC/DISPCC/GCC/GPUCC/VIDEOCC)
CONFIG_SM_CAMCC_DIWALI=y
CONFIG_SM_DEBUGCC_DIWALI=y
CONFIG_SM_DISPCC_DIWALI=y
CONFIG_SM_GCC_DIWALI=y
CONFIG_SM_GPUCC_DIWALI=y
CONFIG_SM_VIDEOCC_DIWALI=y

# --- Reset ---
CONFIG_RESET_CONTROLLER=y
CONFIG_QCOM_RESET=y

# --- PDC (Power Domain Controller) ---
CONFIG_QCOM_PDC=y
CONFIG_QCOM_MPM=y
CONFIG_QCOM_MSM_IPCC=y

# --- Dump ---
CONFIG_QCOM_DUMP=y
CONFIG_QCOM_DLOAD_MODE=y

# --- ADC / VADC ---
CONFIG_QCOM_SPMI_VADC=y
CONFIG_QCOM_SPMI_ADC5=y
CONFIG_QCOM_VADC_COMMON=y

# --- SPMI ---
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y

# --- Haptics ---
CONFIG_QCOM_SPMI_HAPTICS=y
CONFIG_INPUT_QCOM_HAPTICS=y
CONFIG_INPUT_QCOM_HV_HAPTICS=y
CONFIG_PWM_QTI_LPG=y

# --- PMIC ---
CONFIG_MFD_SPMI_PMIC=y
CONFIG_MFD_I2C_PMIC=y
CONFIG_QPNP_PBS=y

# --- DMA-BUF heaps ---
CONFIG_QCOM_DMABUF_HEAPS=y
CONFIG_QCOM_DMABUF_HEAPS_SYSTEM=y
CONFIG_QCOM_DMABUF_HEAPS_CMA=y
CONFIG_QCOM_DMABUF_HEAPS_SYSTEM_SECURE=y
CONFIG_QCOM_DMABUF_HEAPS_CARVEOUT=y

# --- MHI bus (modem control) ---
CONFIG_MHI_BUS=y
CONFIG_MHI_QCOM=y
CONFIG_MHI_NETDEV=y
CONFIG_MHI_DTR=y
CONFIG_MHI_UCI=y

# --- IPA (IP Accelerator) ---
CONFIG_IPA3=y

# --- EDAC ---
CONFIG_EDAC_KRYO_ARM64=y
CONFIG_EDAC_QCOM=y
CONFIG_EDAC_QCOM_LLCC_PANIC_ON_UE=y

# --- CoreSight (debug tracing) ---
CONFIG_CORESIGHT=y
CONFIG_CORESIGHT_CTI=y
CONFIG_CORESIGHT_DUMMY=y
CONFIG_CORESIGHT_HWEVENT=y
CONFIG_CORESIGHT_LINKS_AND_SINKS=y
CONFIG_CORESIGHT_LINK_AND_SINK_TMC=y
CONFIG_CORESIGHT_REMOTE_ETM=y
CONFIG_CORESIGHT_STM=y
CONFIG_CORESIGHT_SOURCE_ETM4X=y

# --- FSA4480 (USB-C analog audio switch) ---
CONFIG_QCOM_FSA4480_I2C=y

# --- QCOM IRQ stats ---
CONFIG_QCOM_IRQ_STAT=y
CONFIG_QCOM_WDT_CORE=y
CONFIG_QCOM_WATCHDOG_BARK_TIME=20000
CONFIG_QCOM_WATCHDOG_PET_TIME=15000
CONFIG_QCOM_WATCHDOG_IPI_PING=y
CONFIG_QCOM_WATCHDOG_WAKEUP_ENABLE=y

# --- QRTR (QIPCRTR) ---
CONFIG_QRTR=y
CONFIG_QRTR_MHI=y
CONFIG_QRTR_SMD=y
CONFIG_QRTR_GUNYAH=y
