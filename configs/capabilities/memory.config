# configs/capabilities/memory.config
#
# Memory Management features for Aurora-Kernel (Linux 6.18 LTS)
# All verified against mainline 6.18 Kconfig.

# --- Multi-Generational LRU (MGLRU) ---
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_LRU_GEN_WALKS_MILLIS=y

# --- DAMON (Data Access MONitor) + DAMOS ---
CONFIG_DAMON=y
CONFIG_DAMON_VADDR=y
CONFIG_DAMON_PADDR=y
CONFIG_DAMON_SYSFS=y
CONFIG_DAMON_RECLAIM=y
CONFIG_DAMON_LRU_SORT=y

# --- Multi-size Transparent Huge Pages (mTHP) ---
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_TRANSPARENT_HUGEPAGE_PUD=n
CONFIG_READ_ONLY_THP_FOR_FS=y
# mTHP is runtime-configurable via /sys/kernel/mm/transparent_hugepage/
# no separate Kconfig needed in 6.18 (it's part of THP)

# --- zRAM optimization ---
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_ZSTD=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_MEMORY_TRACKING=y
CONFIG_ZRAM_MULTI_COMP=y

# --- zswap ---
CONFIG_ZSWAP=y
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_ZBUD=y
CONFIG_Z3FOLD=y
CONFIG_ZSMALLOC=y

# --- Proactive compaction ---
CONFIG_COMPACTION=y
CONFIG_PAGE_REPORTING=y

# --- Folios (page-based memory management, default since 6.x) ---
# Folios are always enabled in 6.18 — no Kconfig; they're core infrastructure

# --- Per-VMA locking (reduces mmap_lock contention) ---
CONFIG_PER_VMA_LOCK=y

# --- Maple Tree VMAs (replaces red-black tree for VMA tracking) ---
# Always enabled in 6.18 core — no separate Kconfig

# --- PSI (Pressure Stall Information) ---
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=y

# --- Memory cgroup optimization ---
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_MEMCG_V1=y
CONFIG_MEMCG_KMEM=y
CONFIG_CGROUP_MEM_ACCOUNT=y

# --- Slab optimization ---
CONFIG_SLUB=y
CONFIG_SLUB_CPU_PARTIAL=y
CONFIG_SLAB_MERGE_DEFAULT=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SLUB_DEBUG=y

# --- KSM (Kernel Samepage Merging) ---
CONFIG_KSM=y

# --- Frontswap / THP swap ---
CONFIG_THP_SWAP=y
CONFIG_FRONTSWAP=y

# --- Memory hotplug ---
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_ISOLATION=y
CONFIG_MIGRATION=y
CONFIG_CONTIG_ALLOC=y

# --- CMA ---
CONFIG_CMA=y
CONFIG_CMA_DEBUGFS=y
CONFIG_CMA_AREAS=8
CONFIG_CMA_SIZE_PERCENTAGE=10
CONFIG_CMA_SIZE_MBYTES=64

# --- DMA pools ---
CONFIG_DMA_CMA=y
CONFIG_GENERIC_ALLOCATOR=y
