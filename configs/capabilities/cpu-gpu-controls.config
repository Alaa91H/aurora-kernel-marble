# configs/capabilities/cpu-gpu-controls.config
#
# CPU/GPU frequency control & thermal governor profiles for Aurora-Kernel
# (Linux 6.18 LTS)
#
# These enable the sysfs interfaces that the Aurora runtime daemon
# (aurora-tune.sh) uses to switch profiles at runtime.

# --- CPU frequency limits (sysfs: scaling_min/max_freq) ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_TIMES=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_INTERACTIVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPUFREQ_DT=y
CONFIG_CPUFREQ_DT_PLATDEV=y
CONFIG_CPU_FREQ_THERMAL=y

# --- CPU fast-switching (schedutil fast path) ---
CONFIG_CPU_FREQ_GOV_SCHEDUTIL_FAST=y

# --- uclamp (per-task frequency clamping) ---
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_TASK_GROUP=y
CONFIG_DEFAULT_UCLAMP_MAX=1024
CONFIG_DEFAULT_UCLAMP_MIN=0

# --- schedtune (per-cgroup scheduler boost) ---
CONFIG_CGROUP_SCHEDTUNE=y
CONFIG_SCHED_TUNE=y

# --- GPU frequency control (sysfs: devfreq) ---
CONFIG_PM_DEVFREQ=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_GOV_PERFORMANCE=y
CONFIG_DEVFREQ_GOV_POWERSAVE=y
CONFIG_DEVFREQ_GOV_USERSPACE=y
CONFIG_DEVFREQ_GOV_PASSIVE=y
CONFIG_QCOM_KGSL=y
CONFIG_QCOM_KGSL_HWMON=y

# --- Thermal governor profiles ---
CONFIG_THERMAL=y
CONFIG_THERMAL_WRITABLE_TRIPS=y
CONFIG_THERMAL_DEFAULT_GOV_POWER_ALLOCATOR=y
CONFIG_THERMAL_GOV_FAIR_SHARE=y
CONFIG_THERMAL_GOV_STEP_WISE=y
CONFIG_THERMAL_GOV_USER_SPACE=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y
CONFIG_THERMAL_EMULATION=y

# --- Thermal pressure (feeds into scheduler for frequency capping) ---
CONFIG_SCHED_THERMAL_PRESSURE=y

# --- DVFS (Dynamic Voltage & Frequency Scaling) ---
# Enabled via CPUFreq + OPP + Regulator framework:
CONFIG_OPP=y
CONFIG_PM_OPP=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_QCOM_RPMH=y

# --- Interconnect (ICC) bandwidth voting ---
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_WAIPIO=y
CONFIG_INTERCONNECT_QCOM_SM8450=y

# --- LLCC QoS (Last-Level Cache quality of service) ---
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_LLCC_QOS=y

# --- Performance monitoring (for Aurora telemetry) ---
CONFIG_PERF_EVENTS=y
CONFIG_HW_PERF_EVENTS=y
CONFIG_ARM_PMU=y
CONFIG_ARM_PMUV3=y
CONFIG_ARM_DSU_PMU=y
CONFIG_QCOM_L3_PMU=y
