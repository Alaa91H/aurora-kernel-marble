# configs/capabilities/storage.config
#
# Storage & I/O features for Aurora-Kernel (Linux 6.18 LTS)

# --- blk-mq (multi-queue block layer, default in 6.18) ---
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_INTEGRITY=y
CONFIG_BLK_DEV_ZONED=y
CONFIG_BLK_DEV_THROTTLING=y
CONFIG_BLK_DEV_THROTTLING_LOW=y
CONFIG_BLK_WBT=y
CONFIG_BLK_WBT_MQ=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_CGROUP_RWSTAT=y
CONFIG_BLK_CGROUP_IOCOST=y
CONFIG_BLK_CGROUP_IOPRIO=y
CONFIG_BLK_INLINE_ENCRYPTION=y
CONFIG_BLK_INLINE_ENCRYPTION_FALLBACK=y

# --- UFS MCQ (Multi-Circular Queue) ---
CONFIG_SCSI=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y
CONFIG_SCSI_UFS_QCOM=y
CONFIG_SCSI_UFS_CRYPTO=y
CONFIG_SCSI_UFS_HPB=y
CONFIG_SCSI_UFS_HWMON=y
CONFIG_SCSI_UFS_MCQ=y
CONFIG_SCSI_UFS_TI_JTAG=y

# --- Inline Encryption (ICE — Inline Crypto Engine) ---
CONFIG_BLK_INLINE_ENCRYPTION=y
CONFIG_FS_ENCRYPTION_INLINE_CRYPT=y
CONFIG_CRYPTO_DEV_QCOM_ICE=y

# --- io_uring ---
CONFIG_IO_URING=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_AIO=y

# --- F2FS advanced ---
CONFIG_F2FS_FS=y
CONFIG_F2FS_STAT_FS=y
CONFIG_F2FS_FS_XATTR=y
CONFIG_F2FS_FS_POSIX_ACL=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_F2FS_CHECK_FS=n
CONFIG_F2FS_FAULT_INJECTION=n
CONFIG_F2FS_FS_COMPRESSION=y
CONFIG_F2FS_FS_LZO=y
CONFIG_F2FS_FS_LZ4=y
CONFIG_F2FS_FS_ZSTD=y
CONFIG_F2FS_FS_LZORLE=y
CONFIG_F2FS_FS_ENCRYPTION=y

# --- EXT4 Fast Commit ---
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_EXT4_FS_ENCRYPTION=y
CONFIG_JBD2=y
CONFIG_JBD2_DEBUG=n

# --- EROFS (read-only compressed filesystem for system/vendor) ---
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_XATTR=y
CONFIG_EROFS_FS_POSIX_ACL=y
CONFIG_EROFS_FS_SECURITY=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_LZ4=y
CONFIG_EROFS_FS_ZIP_DEFLATE=y
CONFIG_EROFS_FS_PCPU_KTHREAD=y

# --- Incremental FS (Android AOT app installation) ---
CONFIG_INCREMENTAL_FS=y

# --- Page cache / writeback ---
CONFIG_PAGE_CACHE=y
CONFIG_FSCACHE=y
CONFIG_FSCACHE_STATS=y
CONFIG_CACHEFILES=y

# --- Read-ahead optimization ---
# Controlled at runtime via /sys/block/*/queue/read_ahead_kb

# --- rq_qos ---
CONFIG_BLK_RQ_ALLOC_TIME=y
CONFIG_BLK_RQ_QOS=y

# --- I/O schedulers ---
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_IOSCHED_BFQ=y
CONFIG_BFQ_GROUP_IOSCHED=y

# --- Async buffered IO ---
# io_uring provides async buffered IO; no separate Kconfig

# --- NVMe (for future devices) ---
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y
CONFIG_NVME_HWMON=y
