# configs/vendor/marble_GKI.config
#
# Authoritative marble GKI vendor config — VERIFIED from Xiaomi marble-s-oss.
# Source: MiCode/Xiaomi_Kernel_OpenSource, branch marble-s-oss,
# file arch/arm64/configs/vendor/marble_GKI.config
#
# This file is merged on top of gki_defconfig + waipio_GKI.config +
# xiaomi_GKI.config during the build, exactly as Xiaomi does.
#
# Key facts confirmed:
#   - 3 platform arches: ARCH_WAIPIO + ARCH_DIWALI + ARCH_CAPE
#   - Clock controllers: MSM_*CC_WAIPIO (GCC/GPUCC/CAMCC/DEBUGCC/DISPCC/VIDEOCC)
#     + SM_*CC_DIWALI (CAMCC/DEBUGCC/DISPCC/GCC/GPUCC/VIDEOCC)
#   - 3 pinctrls: PINCTRL_WAIPIO + PINCTRL_DIWALI + PINCTRL_CAPE
#   - 3 interconnects: INTERCONNECT_QCOM_WAIPIO + DIWALI + PARROT
#   - Audio: SLIMbus (CONFIG_SLIMBUS, CONFIG_BTFM_SLIM)
#   - WCD934X disabled (marble uses WCD9375)
#   - WiFi: CNSS2 + ICNSS2 (QCA6490 via PCIE)
#   - Hypervisor: Gunyah (CONFIG_GUNYAH_DRIVERS, CONFIG_GH_*)
#   - Most vendor drivers are =m (GKI modules), not =y

# --- Platform arches (3 platforms for marble) ---
CONFIG_ARCH_CAPE=y
CONFIG_ARCH_DIWALI=y
CONFIG_ARCH_WAIPIO=y

# --- CPUFreq ---
CONFIG_ARM_QCOM_CPUFREQ_HW=m
CONFIG_ARM_QCOM_CPUFREQ_HW_DEBUG=m

# --- ARM SMMU ---
CONFIG_ARM_SMMU=m
CONFIG_ARM_SMMU_CONTEXT_FAULT_RETRY=y
CONFIG_ARM_SMMU_DISABLE_BYPASS_BY_DEFAULT=y

# --- Audio (SLIMbus, NOT SoundWire) ---
CONFIG_BTFM_SLIM=m
CONFIG_SLIMBUS=m
CONFIG_SLIM_QCOM_NGD_CTRL=m
# CONFIG_MFD_WCD934X is not set
# CONFIG_SND_SOC_WCD9335 is not set
CONFIG_SND_USB_AUDIO_QMI=m
CONFIG_MSM_BT_POWER=m

# --- WiFi (CNSS2 + ICNSS2, QCA6490 via PCIE) ---
CONFIG_CNSS2=m
CONFIG_CNSS2_QMI=y
CONFIG_CNSS_GENL=m
CONFIG_CNSS_UTILS=m
CONFIG_ICNSS2=m
CONFIG_ICNSS2_QMI=y
CONFIG_CFG80211=m
CONFIG_CFG80211_REQUIRE_SIGNED_REGDB=y
CONFIG_CFG80211_USE_KERNEL_REGDB_KEYS=y
CONFIG_CFG80211_DEFAULT_PS=y
CONFIG_CFG80211_CRDA_SUPPORT=y
CONFIG_MAC80211=m
CONFIG_MAC80211_HAS_RC=y
CONFIG_MAC80211_RC_DEFAULT="minstrel_ht"
CONFIG_MAC80211_RC_DEFAULT_MINSTREL=y
CONFIG_MAC80211_RC_MINSTREL=y
CONFIG_WCNSS_MEM_PRE_ALLOC=m
# CONFIG_MI_WIRELESS is not set
CONFIG_MI_CNSS_STATISTIC=m

# --- Clock controllers (MSM_WAIPIO + SM_DIWALI) ---
CONFIG_COMMON_CLK_QCOM=m
CONFIG_MSM_GCC_WAIPIO=m
CONFIG_MSM_CAMCC_WAIPIO=m
CONFIG_MSM_DEBUGCC_WAIPIO=m
CONFIG_MSM_DISPCC_WAIPIO=m
CONFIG_MSM_GPUCC_WAIPIO=m
CONFIG_MSM_VIDEOCC_WAIPIO=m
CONFIG_SM_CAMCC_DIWALI=m
CONFIG_SM_DEBUGCC_DIWALI=m
CONFIG_SM_DISPCC_DIWALI=m
CONFIG_SM_GCC_DIWALI=m
CONFIG_SM_GPUCC_DIWALI=m
CONFIG_SM_VIDEOCC_DIWALI=m
CONFIG_QCOM_CLK_RPMH=m

# --- Pinctrl (3 platforms) ---
CONFIG_PINCTRL_WAIPIO=m
CONFIG_PINCTRL_DIWALI=m
CONFIG_PINCTRL_CAPE=m
CONFIG_PINCTRL_QCOM_SPMI_PMIC=m

# --- Interconnect (3 platforms) ---
CONFIG_INTERCONNECT_QCOM=m
CONFIG_INTERCONNECT_QCOM_WAIPIO=m
CONFIG_INTERCONNECT_QCOM_DIWALI=m
CONFIG_INTERCONNECT_QCOM_PARROT=m
CONFIG_INTERCONNECT_QCOM_DEBUG=m

# --- Display ---
CONFIG_MSM_EXT_DISPLAY=m
CONFIG_DRM_LONTIUM_LT9611UXC=m
CONFIG_REGULATOR_QPNP_AMOLED=m
CONFIG_SENSORS_QTI_AMOLED_ECM=m

# --- GPU (Adreno 725) ---
CONFIG_QCOM_KGSL=m
CONFIG_QCOM_KGSL_CONTEXT_DEBUG=y
CONFIG_QCOM_KGSL_IOCOHERENCY_DEFAULT=y
CONFIG_DEVFREQ_GOV_QCOM_ADRENO_TZ=m
CONFIG_DEVFREQ_GOV_QCOM_GPUBW_MON=m

# --- Gunyah hypervisor ---
CONFIG_GUNYAH_DRIVERS=y
CONFIG_GH_ARM64_DRV=m
CONFIG_GH_CTRL=m
CONFIG_GH_DBL=m
CONFIG_GH_IRQ_LEND=m
CONFIG_GH_MEM_NOTIFIER=m
CONFIG_GH_MSGQ=m
CONFIG_GH_RM_DRV=m
CONFIG_GH_VIRTIO_BACKEND=m
