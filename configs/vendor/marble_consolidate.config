# configs/vendor/marble_consolidate.config
#
# Authoritative marble consolidate config — VERIFIED from Xiaomi marble-s-oss.
# Source: MiCode/Xiaomi_Kernel_OpenSource, branch marble-s-oss,
# file arch/arm64/configs/vendor/marble_consolidate.config
#
# This config adds debug/diagnostic features on top of marble_GKI.config.

# --- ARM SMMU debug ---
CONFIG_ARM_SMMU_CAPTUREBUS_DEBUGFS=y
CONFIG_ARM_SMMU_TESTBUS_DEBUGFS=y
CONFIG_ARM_SMMU_TESTBUS_DUMP=y

# --- CoreSight ETM4X ---
CONFIG_CORESIGHT_SOURCE_ETM4X=m
# CONFIG_CORESIGHT_TRBE is not set
# CONFIG_ETM4X_IMPDEF_FEATURE is not set

# --- Debug features ---
CONFIG_ATOMIC64_SELFTEST=m
CONFIG_CNSS2_DEBUG=y
CONFIG_ICNSS2_DEBUG=y
CONFIG_HYP_ASSIGN_DEBUG=y
CONFIG_IOMMU_TLBSYNC_DEBUG=y
CONFIG_LKDTM=m
CONFIG_LOCK_TORTURE_TEST=m
CONFIG_PAGE_POISONING=y
CONFIG_RCU_TORTURE_TEST=m
CONFIG_SLUB_DEBUG_ON=y
CONFIG_TEST_USER_COPY=m
CONFIG_OF_RESERVED_MEM_CHECK=y
CONFIG_QCOM_KGSL_FENCE_TRACE=y
CONFIG_QCOM_PCI_EDMA_DEBUG=y
CONFIG_QCOM_VA_MINIDUMP=m
CONFIG_QCOM_RTB=m
CONFIG_QCOM_RTB_SEPARATE_CPUS=y
CONFIG_QTI_PMIC_GLINK_CLIENT_DEBUG=y
CONFIG_QTI_THERMALZONE_CONFIG_DEBUG=m
CONFIG_REGMAP_QTI_DEBUGFS_ALLOW_WRITE=y
CONFIG_SDHCI_MSM_DBG=y
CONFIG_SERIAL_MSM_GENI_CONSOLE_DEFAULT_ENABLED=y
CONFIG_UFS_DBG=y
CONFIG_DEBUG_DMA_BUF_REF=m
CONFIG_MHI_BUS_DEBUG=y
CONFIG_MSM_GPI_DMA_DEBUG=y
CONFIG_EDAC_KRYO_ARM64_PANIC_ON_CE=y
CONFIG_EDAC_QCOM_LLCC_PANIC_ON_CE=y

# --- SPS ---
CONFIG_SPS=m
CONFIG_SPS_SUPPORT_NDP_BAM=y

# --- Fingerprint (consolidate) ---
CONFIG_INPUT_FINGERPRINT=y
CONFIG_FINGERPRINT_XIAOMI_FP=m
CONFIG_FINGERPRINT_FPC_1540=m
CONFIG_FINGERPRINT_GOODIX_3626=m

# --- Input / IR ---
CONFIG_LIRC=y
CONFIG_RC_CORE=y
CONFIG_RC_DECODERS=y
CONFIG_RC_DEVICES=y
CONFIG_IR_SPI=m

# --- Watchdog / GPIO ---
CONFIG_FIRE_WATCHDOG=y
CONFIG_GPIO_TESTING_MODE=y

# --- USB networking ---
CONFIG_USB_NET_AX88179_178A=m
CONFIG_USB_NET_AX8817X=m

# --- Debug logging ---
CONFIG_XLOGCHAR=m
# CONFIG_SCHED_WALT_DEBUG is not set
