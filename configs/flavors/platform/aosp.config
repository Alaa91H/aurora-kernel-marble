# configs/flavors/platform/aosp.config
#
# Platform flavor: AOSP (Android Open Source Project)
# Primary target — vanilla AOSP, LineageOS, Evolution X, crDroid, etc.
#
# All AOSP-compatible ROMs use the same GKI interface. This fragment
# ensures standard Android subsystems are enabled.
#
# Merged at: Platform Layer (after Core, before Root/Profile)

# --- Android core (already in base defconfig, reinforced here) ---
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ASHMEM=y

# --- AOSP debugfs / tracing ---
CONFIG_DEBUG_FS=y
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y

# --- AOSP ION / DMA-BUF heaps ---
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_ION=y
CONFIG_ION_SYSTEM_HEAP=y
CONFIG_ION_CMA_HEAP=y

# --- Incremental FS (AOT app installation) ---
CONFIG_INCREMENTAL_FS=y

# --- Staged driver model ---
CONFIG_SND_SOC_QCOM=y

# --- Vendor hooks (GKI requirement) ---
CONFIG_ANDROID_VENDOR_HOOKS=y
