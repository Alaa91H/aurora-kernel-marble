# configs/flavors/platform/hyperos.config
#
# Platform flavor: HyperOS (Xiaomi MIUI successor)
# Target: Xiaomi HyperOS / MIUI ROMs on marble
#
# HyperOS adds vendor-specific userspace components that may need:
#   - Specific ION heap names
#   - MIUI sensor hub (slpi)
#   - MIUI power HAL hooks
#   - Additional debugfs for mi_health
#
# The kernel side is identical to AOSP (HyperOS uses the same GKI
# interface), but these options ensure vendor HAL compatibility.
#
# Merged at: Platform Layer (after Core, before Root/Profile)

# --- Include all AOSP base (HyperOS is AOSP-compatible) ---
# (the build script merges aosp.config + hyperos.config)

# --- Xiaomi/HyperOS vendor hooks ---
CONFIG_ANDROID_VENDOR_HOOKS=y
CONFIG_XIAOMI_KERNEL_FEATURE=y

# --- MIUI sensor hub (SLPI communication) ---
CONFIG_QCOM_PIL_INFO=y
CONFIG_QCOM_FASTRPC=y
CONFIG_QCOM_GLINK_SSR=y
CONFIG_QCOM_RMTFS_MEM=y

# --- MIUI power / health ---
CONFIG_BATTERY_BQ27XXX=y
CONFIG_BATTERY_BQ27XXX_I2C=y
CONFIG_CHARGER_QCOM_SMBB=y

# --- MIUI display (DC dimming path) ---
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y

# --- MIUI audio (dirac / dolby userspace needs standard ALSA) ---
CONFIG_SND_SOC=y
CONFIG_SND_SOC_QCOM=y

# --- MIUI perf framework hooks ---
CONFIG_DEVFREQ_GOV_PERFORMANCE=y
CONFIG_DEVFREQ_GOV_POWERSAVE=y

# --- MIUI thermal (per-zone) ---
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_QCOM_TSENS=y
