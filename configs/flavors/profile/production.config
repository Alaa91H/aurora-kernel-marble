# configs/flavors/profile/production.config
#
# Build profile: Production (default)
# Balanced stability + performance + battery. The safe daily driver.
#
# Merged at: Profile Layer (last, overrides all above)

# --- Preemption: dynamic (switchable none/voluntary/full) ---
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_PREEMPT_NONE=y
CONFIG_PREEMPT_VOLUNTARY=y

# --- Scheduler: EAS + schedutil ---
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_SCHED_EAS=y
CONFIG_SCHED_WALT=y
CONFIG_UCLAMP_TASK=y

# --- Memory: MGLRU + DAMON ---
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_DAMON=y

# --- zRAM ---
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y

# --- Thermal: power allocator ---
CONFIG_THERMAL_DEFAULT_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y

# --- Security: KCFI on ---
CONFIG_CFI_CLANG=y
CONFIG_CFI_PERMISSIVE=n

# --- Debug: minimal ---
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_KERNEL=y
CONFIG_MAGIC_SYSRQ=y
