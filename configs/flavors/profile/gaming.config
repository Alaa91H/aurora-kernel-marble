# configs/flavors/profile/gaming.config
#
# Build profile: Gaming
# Maximizes responsiveness and sustained performance.
# Higher clock floors, aggressive foreground priority, reduced latency.
#
# Merged at: Profile Layer (last, overrides all above)

# --- Preemption: full (lowest latency) ---
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_PREEMPT=y
CONFIG_PREEMPT_COUNT=y

# --- Scheduler: boost foreground, reduce background ---
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL_FAST=y
CONFIG_SCHED_EAS=y
CONFIG_SCHED_WALT=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_TASK_GROUP=y
CONFIG_DEFAULT_UCLAMP_MAX=1024

# --- Timer: higher HZ for smoother frame pacing ---
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_SCHED_HRTICK=y

# --- Memory: keep more in RAM, less swapping ---
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_ZRAM=y
# No writeback — keep everything in RAM for speed
# CONFIG_ZRAM_WRITEBACK is not set

# --- I/O: low latency ---
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_BLK_WBT=y
CONFIG_BLK_WBT_MQ=y

# --- Thermal: allow higher temps before throttling (gaming) ---
CONFIG_THERMAL_DEFAULT_GOV_STEP_WISE=y
CONFIG_CPU_THERMAL=y
# Keep power_allocator available but don't make it default
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y

# --- GPU: performance devfreq ---
CONFIG_DEVFREQ_GOV_PERFORMANCE=y

# --- IRQ: threaded for latency ---
CONFIG_IRQ_FORCED_THREADING=y
CONFIG_PREEMPT_RT=n
