# configs/flavors/profile/development.config
#
# Build profile: Development
# Maximum debuggability: KASAN, KFENCE, lockdep, verbose tracing.
# NOT for daily use — slower, larger, for catching bugs.
#
# Merged at: Profile Layer (last, overrides all above)

# --- Preemption: voluntary (good for debugging) ---
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_PREEMPT_VOLUNTARY=y

# --- Debug infrastructure ---
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF5=y
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_FS=y
CONFIG_DEBUG_BUGVERBOSE=y
CONFIG_DEBUG_LIST=y
CONFIG_DEBUG_SG=y
CONFIG_DEBUG_NOTIFIERS=y
CONFIG_DEBUG_CREDENTIALS=y
CONFIG_DEBUG_VIRTUAL=y

# --- Lock debugging ---
CONFIG_DEBUG_MUTEXES=y
CONFIG_DEBUG_RT_MUTEXES=y
CONFIG_DEBUG_SPINLOCK=y
CONFIG_DEBUG_LOCK_ALLOC=y
CONFIG_PROVE_LOCKING=y
CONFIG_LOCKDEP=y
CONFIG_LOCK_TORTURE_TEST=n

# --- Memory debugging ---
CONFIG_KASAN=y
CONFIG_KASAN_GENERIC=y
CONFIG_KASAN_INLINE=y
CONFIG_KFENCE=y
CONFIG_KFENCE_SAMPLE_INTERVAL=100
CONFIG_KMEMLEAK=y
CONFIG_KCSAN=y

# --- Undefined behavior sanitizer ---
CONFIG_UBSAN=y
CONFIG_UBSAN_BOUNDS=y
CONFIG_UBSAN_SHIFT=y
CONFIG_UBSAN_DIV_BY_ZERO=y
CONFIG_UBSAN_UNREACHABLE=y
CONFIG_UBSAN_BOOL=y
CONFIG_UBSAN_ENUM=y

# --- Tracing ---
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_TRACEPOINTS=y
CONFIG_TRACING=y
CONFIG_SCHED_TRACER=y
CONFIG_IRQSOFF_TRACER=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_HIST_TRIGGERS=y

# --- BTF (for BPF debugging) ---
CONFIG_DEBUG_INFO_BTF=y

# --- Security: permissive CFI during dev ---
CONFIG_CFI_CLANG=y
CONFIG_CFI_PERMISSIVE=y

# --- panic on warnings (catch bugs early) ---
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_ON_OOPS_VALUE=1
CONFIG_PANIC_TIMEOUT=-1

# --- Test infrastructure ---
CONFIG_KUNIT=y
CONFIG_KUNIT_EXAMPLE_TEST=n
CONFIG_LKDTM=y
