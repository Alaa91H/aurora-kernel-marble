# configs/flavors/profile/battery.config
#
# Build profile: Battery Saver
# Maximizes battery life: lower clock ceilings, aggressive idle,
# more swapping, reduced background activity.
#
# Merged at: Profile Layer (last, overrides all above)

# --- Preemption: none (saves CPU cycles at idle) ---
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_PREEMPT_NONE=y
# CONFIG_PREEMPT_VOLUNTARY is not set

# --- Scheduler: schedutil (slow ramp to save power) ---
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_SCHED_EAS=y
CONFIG_SCHED_WALT=y
CONFIG_UCLAMP_TASK=y
CONFIG_DEFAULT_UCLAMP_MAX=512

# --- CPU idle: deepest states ---
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_ARM_PSCI_CPUIDLE=y

# --- Memory: aggressive reclaim + zRAM writeback ---
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_DAMON=y
CONFIG_DAMON_RECLAIM=y
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_DEFAULT_ON=y

# --- Thermal: power allocator (most battery-friendly) ---
CONFIG_THERMAL_DEFAULT_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y

# --- Timer: lower HZ (less wakeups) ---
CONFIG_HZ_100=y
CONFIG_HZ=100

# --- I/O: batch writes ---
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_BLK_WBT=y

# --- GPU: powersave devfreq ---
CONFIG_DEVFREQ_GOV_POWERSAVE=y

# --- Suspend: deep idle ---
CONFIG_PM_SLEEP=y
CONFIG_PM_SLEEP_SMP=y
CONFIG_PM_WAKELOCKS=y
