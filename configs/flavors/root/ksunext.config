# configs/flavors/root/ksunext.config
#
# Root flavor: KernelSU-Next (preferred root solution)
# Built-in root via kprobes, with SUSFS support and enhanced hiding.
#
# Merged at: Root Layer (after Platform, before Profile)

# --- KernelSU-Next core ---
CONFIG_KSU=y
CONFIG_KSU_DEBUG=n
CONFIG_KSU_KPROBES=y
CONFIG_KSU_SUSFS=y
CONFIG_KSU_INSTANCE_PASSWORDS=n

# --- kprobe infrastructure (mandatory) ---
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y
CONFIG_KPROBES_ON_FTRACE=y
CONFIG_HAVE_KPROBES=y
CONFIG_HAVE_KRETPROBES=y

# --- Kallsyms (KSU-Next reads symbol table) ---
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# --- Modules ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y

# --- SELinux interop ---
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y

# --- BPF hooks ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# --- Task accounting ---
CONFIG_TASK_XACCT=y
CONFIG_TASK_IO_ACCOUNTING=y
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=y

# --- SUSFS: filesystem hiding (mount/path/hide) ---
# These are runtime-controlled; the CONFIG enables the infrastructure
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
