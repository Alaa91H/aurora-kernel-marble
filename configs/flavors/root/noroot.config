# configs/flavors/root/noroot.config
#
# Root flavor: NoRoot
# Default release — no root solution compiled into the kernel.
#
# This is the safest variant: maximizes Play Integrity / SafetyNet
# compatibility, smallest attack surface, no kprobe root hooks.
#
# Merged at: Root Layer (after Platform, before Profile)

# --- Explicitly disable all root solutions ---
# CONFIG_KSU is not set
# CONFIG_KSU_KPROBES is not set
# CONFIG_KSU_SUSFS is not set
# CONFIG_KSU_DEBUG is not set

# --- Kprobes: kept enabled for tracing/debugging but no root hooks ---
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y

# --- Module signing (stronger: modules must be signed) ---
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=n
CONFIG_MODULE_SIG_SHA256=y
CONFIG_MODULE_SIG_HASH="sha256"

# --- Hardened security (max for noroot) ---
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LSM="lockdown,yama,loadpin,safesetid,integrity,selinux"
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_LANDLOCK=y

# --- Kptr restrict (hide kernel pointers from userspace) ---
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=n
