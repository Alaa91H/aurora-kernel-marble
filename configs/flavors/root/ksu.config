# configs/flavors/root/ksu.config
#
# Root flavor: KernelSU (upstream)
# Built-in root via kprobes syscall hook.
#
# Merged at: Root Layer (after Platform, before Profile)

# --- KernelSU core (built-in, not module) ---
CONFIG_KSU=y
CONFIG_KSU_DEBUG=n
CONFIG_KSU_KPROBES=y
CONFIG_KSU_SUSFS=n
CONFIG_KSU_INSTANCE_PASSWORDS=n

# --- kprobe infrastructure (mandatory for KSU) ---
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y
CONFIG_KPROBES_ON_FTRACE=y
CONFIG_HAVE_KPROBES=y
CONFIG_HAVE_KRETPROBES=y

# --- Kallsyms (KSU needs to read symbol table) ---
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# --- Modules ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y

# --- SELinux interop (KSU patches selinux state) ---
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y

# --- BPF hooks (KSU uses BPF for hiding) ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# --- Task accounting (KSU hiding needs these) ---
CONFIG_TASK_XACCT=y
CONFIG_TASK_IO_ACCOUNTING=y
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=y
