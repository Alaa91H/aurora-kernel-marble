# configs/flavors/root/apatch.config
#
# Root flavor: APatch (kernel-patch based root)
# APatch uses a different mechanism than KSU: it patches the kernel
# image in-memory at boot via a patch file, not kprobes.
#
# APatch requires:
#   - KALLSYMS for symbol resolution
#   - Module support (ships as .ko)
#   - No forced module signing (APatch patches modules)
#
# Merged at: Root Layer (after Platform, before Profile)

# --- APatch does not use CONFIG_KSU; it's userspace-driven ---
# CONFIG_KSU is not set

# --- KALLSYMS (APatch resolves symbols to apply patches) ---
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# --- Modules (APatch ships as loadable .ko) ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=n
# Module signing must NOT be forced (APatch injects its own module)
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=n

# --- kprobes (APatch can use kprobes as fallback hook) ---
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y

# --- SELinux interop ---
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y

# --- BPF ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y

# --- Livepatch (APatch can use livepatch infrastructure) ---
CONFIG_LIVEPATCH=y
CONFIG_LIVEPATCH_IPA_CLANG=y
