# configs/fragments/display.config
#
# Display subsystem + refresh-rate + panel power optimization for marble.
#
# marble has a 120Hz AMOLED (Tianma/CSOT). The kernel controls:
#   - DSI command-mode vs video-mode
#   - Panel TE (tearing effect) signalling
#   - Refresh-rate switching (where the panel supports it)
#   - Backlight PWM (for AOD dimming / DC dimming)
#
# Merged on top of marble_defconfig by scripts/config-merge.sh

# --- DRM / MSM ---
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_DSI=y
CONFIG_DRM_MSM_DSI_28NM_PHY=y
CONFIG_DRM_MSM_DSI_28NM_8960_PHY=y
CONFIG_DRM_MSM_DSI_14NM_PHY=y
CONFIG_DRM_MSM_DSI_10NM_PHY=y
CONFIG_DRM_MSM_DSI_7NM_PHY=y
CONFIG_DRM_MSM_HDMI_HDCP=y

# DSI panel infrastructure
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_MIPI_DSI=y
CONFIG_DRM_PANEL_BRIDGE=y
CONFIG_DRM_PANEL_ORIENTATION_QUIRKS=y

# Panel drivers (marble uses Tianma + CSOT AMOLED)
CONFIG_DRM_PANEL_TIANMA=y
CONFIG_DRM_PANEL_CSOT=y
CONFIG_DRM_PANEL_SAMSUNG=y

# --- Refresh rate / FPS ---
# The kernel does NOT directly set "120Hz/60Hz" — that is driven by the
# SurfaceFlinger/HWC via DSI dynamic refresh. The kernel provides:
#   - DSI command queue (for panel mode-switch commands)
#   - Frame TE interrupt (vblank) for vsync alignment
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_FBDEV_OVERALLOC=100
CONFIG_FB=y
CONFIG_FB_CMDLINE=y
CONFIG_FB_NOTIFY=y

# vblank / TE
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_KMS_FB_HELPER=y
CONFIG_DRM_VBLANK=y
CONFIG_DRM_PANIC=y

# --- Backlight ---
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_LCD_SUPPORT=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_BACKLIGHT_LP855X=y
CONFIG_BACKLIGHT_QCOM_WLED=y
CONFIG_PWM=y
CONFIG_PWM_QCOM=y
CONFIG_QCOM_PWM=y

# DC Dimming support path (PWM-driven, not a magic kernel flag)
CONFIG_QCOM_MDSS_DP=y
CONFIG_QCOM_MDSS_DSI=y
CONFIG_QCOM_MDSS_DSI_CTRL=y
CONFIG_QCOM_MDSS_DSI_PLL=y

# --- GPU (Adreno 725) for display composition ---
CONFIG_DRM_MSM_DPU=y
CONFIG_QCOM_KGSL=y
CONFIG_QCOM_KGSL_HWMON=y
CONFIG_QCOM_ADRENO_GPU=y
CONFIG_QCOM_ADRENO_SMMU=y

# --- Power: panel power domains ---
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_RPMPD=y
CONFIG_POWER_DOMAIN=y
