# configs/fragments/ksu.config
# KernelSU-Next integration fragment for marble
# Merged on top of marble_defconfig by scripts/config-merge.sh
#
# KernelSU-Next requires kprobes; on arm64 we also enable the hooks that
# let KSU intercept the syscall table safely.

CONFIG_KSU=y
CONFIG_KSU_DEBUG=n
CONFIG_KSU_SUSFS=y
CONFIG_KSU_KPROBES=y
CONFIG_KSU_INSTANCE_PASSWORDS=n

# kprobe infrastructure (mandatory)
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y
CONFIG_KPROBES_ON_FTRACE=y
CONFIG_HAVE_KPROBES=y
CONFIG_HAVE_KRETPROBES=y

# /proc/sys/kernel/kptr_restrict — KSU needs to read kallsyms
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# Modules (KSU can ship as module or built-in; built-in preferred)
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y

# SELinux interop — KSU patches selinux state, keep develop mode
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y

# BPF hooks KSU uses for hide
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# Workqueue / task hiding
CONFIG_TASK_XACCT=y
CONFIG_TASK_IO_ACCOUNTING=y
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=y
