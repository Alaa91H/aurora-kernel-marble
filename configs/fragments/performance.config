# configs/fragments/performance.config
# CPU & scheduler optimization fragment for marble (SM7475)
# Merged on top of marble_defconfig by scripts/config-merge.sh
#
# Topology: 1x Cortex-A715 (prime) + 3x Cortex-A715 (gold) + 4x Cortex-A510 (silver)

# --- EAS / scheduling ---
CONFIG_SCHED_EAS=y
CONFIG_SCHED_WALT=y
CONFIG_SCHED_HMP=y
CONFIG_SCHED_CLUSTER=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_TASK_GROUP=y

# schedtune-style boosts are runtime via /dev/stune; keep build defaults neutral
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_SCHEDTUNE=y
CONFIG_SCHED_TUNE=y
CONFIG_DEFAULT_UCLAMP_MAX=1024
CONFIG_DEFAULT_UCLAMP_MIN=0

# --- CPUFreq governors ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_INTERACTIVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y

# fast-switching path
CONFIG_CPU_FREQ_GOV_SCHEDUTIL_FAST=y

# --- HMP / cluster-aware ---
CONFIG_SCHED_CORE=y
CONFIG_SCHED_CORE_IRQ=y

# --- Reduce scheduler latency ---
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_SCHED_HRTICK=y
CONFIG_HRTIMER_BASENODES=y

# --- Prefetch / memory bandwidth ---
CONFIG_ARM64_UARCH_ACCESS_PRIORITY=y
CONFIG_MEMBARRIER=y

# --- ELF / module early-resolve ---
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_KALLSYMS_BASE_RELATIVE=y
