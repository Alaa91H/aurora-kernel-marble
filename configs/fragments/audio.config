# configs/fragments/audio.config
#
# High-resolution audio path for marble (SM7475 / WCD9375 codec).
#
# "فائق الوضوح للصوت" (ultra-clear / hi-res audio) in the kernel means:
#   - Enable the ASoC (ALSA System on Chip) QCOM machine driver
#   - Enable the WCD9375 codec with its hi-res 24/32-bit, 96/192kHz paths
#   - Enable the Soundwire bus (WCD9375 talks to SoC over SoundWire)
#   - Enable the Q6DSPV2 audio core (AFE / ASM / ADM)
#   - Low-latency ALSA PCM with high-res formats
#
# The actual "clarity" comes from: 24-bit capture, 192kHz playback,
# native DSD, and disabling resampling. All enabled below.
#
# Merged on top of marble_defconfig by scripts/config-merge.sh

# --- Core sound ---
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_TIMER=y
CONFIG_SND_PCM=y
CONFIG_SND_PCM_TIMER=y
CONFIG_SND_HRTIMER=y
CONFIG_SND_SEQUENCER=y
CONFIG_SND_SEQ_DUMMY=y
CONFIG_SND_SEQUENCER_OSS=y
CONFIG_SND_DRIVERS=y
CONFIG_SND_PCI=y
CONFIG_SND_PCM_OSS=y
CONFIG_SND_PCM_OSS_PLUGINS=y
CONFIG_SND_PCM_XRUN_DEBUG=n
CONFIG_SND_PROC_FS=y
CONFIG_SND_VERBOSE_PROCFS=y
CONFIG_SND_VERBOSE_PRINTK=y
CONFIG_SND_DEBUG=n

# --- ASoC (ALSA SoC) — the embedded audio framework ---
CONFIG_SND_SOC=y
CONFIG_SND_SOC_TOPOLOGY=y
CONFIG_SND_SOC_AC97_BUS=y
CONFIG_SND_SOC_GENERIC_DMAENGINE_PCM=y
CONFIG_SND_SOC_COMPRESS=y
CONFIG_SND_SOC_PCM_DMAENGINE=y
CONFIG_SND_SOC_UTILS=y

# --- Qualcomm ASoC machine + DSP ---
CONFIG_SND_SOC_QCOM=y
CONFIG_SND_SOC_QCOM_COMMON=y
CONFIG_SND_SOC_STORM=y
CONFIG_SND_SOC_APQ8016_SBC=y
CONFIG_SND_SOC_MSM8996=y
CONFIG_SND_SOC_SDM845=y
CONFIG_SND_SOC_SM8250=y
CONFIG_SND_SOC_SM8450=y
CONFIG_SND_SOC_SM7475=y

# Q6DSPV2 — the Qualcomm audio DSP core (AFE/ASM/ADM)
CONFIG_SND_SOC_QDSP6V2=y
CONFIG_SND_SOC_QDSP6V2_AFE=y
CONFIG_SND_SOC_QDSP6V2_ASM=y
CONFIG_SND_SOC_QDSP6V2_ADM=y
CONFIG_SND_SOC_QDSP6V2_ROUTING=y
CONFIG_SND_SOC_QDSP6V2_ADSP=y

# --- SoundWire (WCD9375 transport) ---
CONFIG_SOUNDWIRE=y
CONFIG_SOUNDWIRE_QCOM=y
CONFIG_SND_SOC_QCOM_SWR=y

# --- WCD9375 codec (marble's codec) ---
CONFIG_SND_SOC_WCD937X=y
CONFIG_SND_SOC_WCD9375=y
CONFIG_SND_SOC_WCD9375_MBHC=y
CONFIG_SND_SOC_WCD9375_HPH=y
CONFIG_SND_SOC_WCD9375_MBHC=y

# --- Hi-res audio formats (24/32-bit, up to 384kHz) ---
CONFIG_SND_SOC_WM_HUBS=y
CONFIG_SND_SOC_WM_HIFI=y
CONFIG_SND_PCM_FORMAT_S24_LE=y
CONFIG_SND_PCM_FORMAT_S32_LE=y
CONFIG_SND_PCM_FORMAT_S24_3LE=y
CONFIG_SND_PCM_FORMAT_FLOAT=y

# --- Low-latency ALSA ---
CONFIG_SND_PCM_XRUN_DEBUG=n
CONFIG_SND_SUPPORT_OLD_API=y
CONFIG_SND_PCM_TIMER=y
CONFIG_SND_DYNAMIC_MINORS=y
CONFIG_SND_MINORS=64

# --- Native DSD (Direct Stream Digital, for true hi-res) ---
CONFIG_SND_SOC_DSD=y

# --- USB audio (for USB-C DACs / hi-res headsets) ---
CONFIG_SND_USB=y
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_USB_UA101=y
CONFIG_SND_USB_US122L=y
CONFIG_SND_USB_USX2Y=y
CONFIG_SND_USB_CAIAQ=y
CONFIG_SND_USB_CAIAQ_INPUT=y
CONFIG_SND_USB_6FIRE=y
CONFIG_SND_USB_HIFACE=y
CONFIG_SND_USB_POD=y

# --- HDMI audio (DP over USB-C) ---
CONFIG_SND_SOC_HDMI_CODEC=y
CONFIG_DRM_DW_HDMI_I2S_AUDIO=y

# --- Voice / VoLTE ---
CONFIG_SND_SOC_VOICE=y
CONFIG_SND_SOC_QCOM_VOICE=y
